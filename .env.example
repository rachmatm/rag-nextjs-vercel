# ----------------------------------------------------------------------------
# Neon PostgreSQL connection string (REQUIRED)
# Get from: https://console.neon.tech -> Your Project -> Connection Details
# Use the POOLED connection string for serverless. Region: ap-southeast-1 (sin1).
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-your-endpoint-pooler.region.aws.neon.tech/dbname?sslmode=require

# ----------------------------------------------------------------------------
# Optional shared-secret to protect the MCP endpoint.
# If set, clients must send it as `Authorization: Bearer <key>` or `x-api-key: <key>`.
# Leave unset to keep the endpoint open (e.g. for local development).
# ----------------------------------------------------------------------------
# MCP_API_KEY=your-long-random-secret
